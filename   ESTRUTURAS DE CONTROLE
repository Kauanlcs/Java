import java.util.Scanner;

public class IntervalinhParImparlenosnl {

    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);

        // Pedir o primeiro número do intervalo
        System.out.print("Digite o primeiro número: ");

        // Lê o número digitado
        int n1 = sc.nextInt();

        // Pedir o segundo número do intervalo
        System.out.print("Digite o segundo número: ");

        // Lê o número digitado
        int n2 = sc.nextInt();

        // Pergunta ao usuário se ele quer números pares ou ímpares
        System.out.print("Digite 1 para PAR ou 2 para ÍMPAR: ");

        // Guarda a escolha do usuário
        int opcao = sc.nextInt();

        // Estrutura de repetição FOR
        // O programa vai percorrer todos os números do intervalo
        // começando do segundo número até chegar no primeiro
        for (int i = n2; i >= n1; i--) {

            // Verifica se o usuário escolheu mostrar números pares
            // i % 2 == 0 significa que o número é par
            if (opcao == 1 && i % 2 == 0) {

                System.out.println(i);

            }

            // Verifica se o usuário escolheu mostrar números ímpares
            // i % 2 != 0 significa que o número é ímpar
            if (opcao == 2 && i % 2 != 0) {

                System.out.println(i);

            }

        }

        sc.close();
    }
}



