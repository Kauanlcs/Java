// Importar a classe Scanner para ler dados digitados no teclado
import java.util.Scanner;

public class imcleninl {

    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);

        // Mostra uma mensagem pedindo a altura
        System.out.print("Digite sua altura: ");

        // Lê o número decimal digitado
        // Usamos double porque altura pode ser decimal (ex: 1.75)
        double altura = sc.nextDouble();

        // Pede o peso da pessoa
        System.out.print("Digite seu peso: ");

        // Lê o peso digitado
        double peso = sc.nextDouble();

        // Calcula o IMC usando a fórmula
        // IMC = peso / (altura × altura)
        double imc = peso / (altura * altura);

        // Mostra o valor calculado
        System.out.println("Seu IMC é: " + imc);

        // Agora começa a classificação do IMC.
        // O programa verifica em qual faixa o valor está.

        // Se o IMC for menor ou igual a 18.5
        if (imc <= 18.5) {

            System.out.println("Abaixo do peso");

        // Se for maior que 18.5 mas menor ou igual a 24.9
        } else if (imc <= 24.9) {

            System.out.println("Peso ideal");

        // Se estiver até 29.9
        } else if (imc <= 29.9) {

            System.out.println("Levemente acima do peso");

        // Se estiver até 34.9
        } else if (imc <= 34.9) {

            System.out.println("Obesidade Grau I");

        // Se estiver até 39.9
        } else if (imc <= 39.9) {

            System.out.println("Obesidade Grau II");

        // Qualquer valor acima disso
        } else {

            System.out.println("Obesidade Grau III");

        }

        sc.close();
    }
}


