import java.util.Scanner;

public class DivisaoControladinlenhon {

    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);

        // Pedir o número inicial
        System.out.print("Digite o número inicial: ");

        // Lê o número digitado
        int primeiro = sc.nextInt();

        int numero;

        // Estrutura de repetição DO-WHILE
        // O DO executa primeiro e só depois verifica a condição
        do {

            // Pede outro número ao usuário
            System.out.print("Digite outro número: ");

            // Lê o número digitado
            numero = sc.nextInt();

        // Continua repetindo enquanto o resto da divisão for 0
        // % é o operador de resto da divisão
        } while (numero % primeiro == 0);

        // Quando a condição não for mais verdadeira o programa sai do loop
        System.out.println("Número inválido digitado. Encerrando...");

        sc.close();
    }
}