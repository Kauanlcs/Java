import java.util.Scanner;

// Cria a classe chamada tabuadadalenonl.
// Todo programa Java precisa estar dentro de uma classe.
public class Ex01Tabuada {


    // A execução do programa sempre começa aqui.
    public static void main(String[] args) {

        // Cria um objeto Scanner chamado "sc".
        // Esse objeto será usado para ler dados do teclado.
        Scanner sc = new Scanner(System.in);

        // Mostra uma mensagem pedindo que o usuário digite um número.
        System.out.print("Digite um número: ");

        // Lê o número inteiro digitado pelo usuário.
        // O valor será armazenado na variável chamada "numero".
        int numero = sc.nextInt();

        // Estrutura de repetição FOR.
        // Ela é usada quando sabemos quantas vezes queremos repetir algo.
        //
        // int i = 1  → cria a variável de controle começando em 1
        // i <= 10    → o laço continua enquanto i for menor ou igual a 10
        // i++        → a cada repetição i aumenta +1
        for (int i = 1; i <= 10; i++) {

            // Aqui o programa mostra cada linha da tabuada.
            // Exemplo se numero = 5:
            // 5 x 1 = 5
            // 5 x 2 = 10
            // etc.

            // numero * i faz a multiplicação da tabuada.
            System.out.println(numero + " x " + i + " = " + (numero * i));

        }

        sc.close();
    }
}



